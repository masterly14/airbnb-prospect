AIRBNB_EMAIL=your-email@example.com
AIRBNB_PASSWORD=your-password-here

# Postgres (Neon) — fuente de verdad compartida por @repo/db
DATABASE_URL="postgresql://user:password@localhost:5432/test_airbnb?schema=public"

# Región Colombia (misma experiencia que tu navegador local)
AIRBNB_BASE_URL=https://www.airbnb.com.co
AIRBNB_LOCALE=es-CO
AIRBNB_TIMEZONE=America/Bogota

# Opcional: usar Chrome instalado en lugar de Chromium
# AIRBNB_BROWSER=chrome

# Composio — Gmail OAuth por cuenta (OTP Airbnb)
COMPOSIO_API_KEY=your-composio-api-key
# Auth Config Gmail del proyecto Composio (Composio Managed Auth, una sola por proyecto)
COMPOSIO_GMAIL_AUTH_CONFIG_ID=your-gmail-auth-config-id
# URL pública del dashboard (callback OAuth)
APP_URL=http://localhost:3000

# Deprecated — usar Conectar Gmail en /settings/accounts por cuenta
# COMPOSIO_USER_ID=your-composio-user-id
# COMPOSIO_CONNECTION_ID=your-connected-account-id

# Deepseek — Agentes IA (Perfilador, Triaje, Negociador)
DEEPSEEK_API_KEY=your-deepseek-api-key
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# Agentes conversacionales (Triaje + Negociador)
# CONVERSATION_BOT_REPLY_LIMIT=2        # Kill switch: máx. respuestas del bot tras enviar Cal.com
# CONVERSATION_MAX_REPLY_CHARS=600      # Espejo de longitud en policy post-LLM
# CONVERSATION_HISTORY_LIMIT=20         # Mensajes recientes hidratados como contexto

# Harvest worker
# HARVEST_MAX_LISTINGS=20
# HARVEST_MAX_PAGES=3
# ICP estático en apps/scraper/src/discovery/icp.ts (10–25 props, superhost)
# ICP_INCLUDE_OPTIONAL_MARKETS=false
# Harvest worker (legacy sin cuenta: usa HARVEST_MARKET / HARVEST_MARKETS)
# Con cuenta de prospección (MVP/prod): usa ProspectAccount.market en Neon — ignora estas vars
# HARVEST_MARKET=Medellín
# HARVEST_MARKETS=Medellín,Bogotá
# HARVEST_ROTATE_MARKETS=true
# HARVEST_HEADED=true
# HARVEST_ENRICH_SYNC=false
# HARVEST_MUTEX_RETRIES=3
# HARVEST_MUTEX_RETRY_DELAY_MS=30000
# HARVEST_LISTING_RETRIES=3
# HARVEST_LISTING_RETRY_DELAY_MS=2000

# Enrichment worker
# ENRICH_BATCH_SIZE=10

# Worker HTTP (container Playwright)
# WORKER_PORT=8080
#
# --- Proxy residencial (Decodo) ---
# Credenciales del dashboard (Residential → Proxy setup). Usadas por:
#   npm run proxy:assign-decodo
# DECODO_USERNAME=                  # parte base del Username (sin user- ni -sessionduration-…)
# DECODO_PASSWORD=                  # Password de la fila (ojo del dashboard)
# DECODO_HOST=gate.decodo.com
# DECODO_STICKY_MODE=port           # port = puertos 10001+ (como el dashboard); session = :7000
# DECODO_STICKY_PORT_START=10001
# DECODO_SESSION_DURATION_MINUTES=60
# DECODO_COUNTRY=random             # random | co | us | …
#
# Por cuenta: 1 puerto sticky distinto (10001, 10002…). Asignar con proxy:assign-decodo.
#
# Master: habilita proxy por defecto en outbound + login (verify-account).
# PLAYWRIGHT_USE_ACCOUNT_PROXY=true
#
# Overrides por job (true/false). Defaults cuando no se definen:
#   outbound/login → siguen el master
#   harvest/inbound/sync → false (red directa; ahorra GB)
# OUTBOUND_USE_ACCOUNT_PROXY=true
# LOGIN_USE_ACCOUNT_PROXY=true
# HARVEST_USE_ACCOUNT_PROXY=false
# INBOUND_USE_ACCOUNT_PROXY=false
# SYNC_USE_ACCOUNT_PROXY=false
#
# Bloquea imágenes/media/fuentes/trackers/CDN fotos Airbnb (~60–80% menos tráfico).
# PLAYWRIGHT_BLOCK_HEAVY_ASSETS=true   # false = cargar página completa
#
# Harvest: ICP → cold message en la misma sesión (sin cola LEAD_DISCOVERED).
# HARVEST_SEND_IMMEDIATE=true   # false = solo descubrir
# HARVEST_SEND_MAX=10
# HARVEST_SEND_UNTIL_BLOCKED=true  # seguir hasta RATE_LIMIT/IDENTITY (tope safety 200)
# HARVEST_HEADED=true
#
# Conexión lenta: duplica timeouts y espera load + networkidle antes de interactuar.
# PLAYWRIGHT_SLOW_NETWORK=true
# PLAYWRIGHT_NAV_TIMEOUT_MS=90000
# PLAYWRIGHT_ACTION_TIMEOUT_MS=60000
# PLAYWRIGHT_NETWORK_IDLE_MS=40000
# PLAYWRIGHT_SETTLE_DELAY_MS=4000

# Outbound worker (el tamaño de oleada lo fija OPERATIONS.MSGS_PER_WAVE en icp.ts)
# OUTBOUND_MAX_CONSECUTIVE_FAILURES=3   # Fallos seguidos antes de rotar de cuenta
# OUTBOUND_AUTO_LOGIN=true              # false = no reintentar login por cuenta (solo sesiones en disco)
# OUTBOUND_FU1_DELAY_DAYS=3
# OUTBOUND_FU2_DELAY_DAYS=5
# OUTBOUND_FU3_DELAY_DAYS=7
# OUTBOUND_LEAD_DELAY_MS=3000
# OUTBOUND_REQUIRE_ENRICHMENT=false
# OUTBOUND_HEADED=true
# CAL_COM_LINK=cal.com/agent-pilot/diagnostico

# Sync de cuentas manuales (sync:accounts) — por defecto sin proxy de cuenta
# SYNC_USE_ACCOUNT_PROXY=false          # true = usar proxy residencial de la cuenta (opt-in)
# SYNC_ACCOUNT_DELAY_MS=45000           # Pausa entre cuentas para evitar rate-limit en auto-login
# SYNC_HEADED=false                     # Por defecto abre navegador si hace falta login; false = headless

# Cal.com webhook (Settings → Developer → Webhooks → BOOKING_CREATED)
# CALCOM_WEBHOOK_SECRET=your-webhook-secret

# Dashboard / API de operadores
# DASHBOARD_TOKEN=your-dashboard-token              # Server: protege /api/leads* y /api/metrics
# NEXT_PUBLIC_DASHBOARD_TOKEN=your-dashboard-token  # Client: token enviado por el dashboard
# NEXT_PUBLIC_USE_MOCK=false                        # true = dashboard con datos mock (sin DB)

# Cifrado at-rest de credenciales (32 bytes en base64)
# Generar: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# CREDENTIALS_ENCRYPTION_KEY=your-base64-32-byte-key

# Multi-cuenta / rotación (Fase C)
# PROSPECT_ACCOUNT_LABEL=Legacy

# MVP: una sola cuenta de prospección (desactiva rotación multi-cuenta)
# Activa esto para el lanzamiento inicial: todos los jobs usan una cuenta fija.
MVP_SINGLE_ACCOUNT=true
MVP_ACCOUNT_ID=69b667ad-a532-444e-a084-44ac7943daa8

# Alertas operativas (Resend — único canal operativo)
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM=Agent Pilot <alerts@your-domain.com>
# Destinatario de captcha / sesión manual / cooldown (default svaron066@gmail.com)
# OPERATIONAL_ALERT_EMAIL=svaron066@gmail.com
# HANDOFF_EMAIL=svaron066@gmail.com
# APP_URL=http://localhost:3000
# DASHBOARD_URL=https://app.example.com
# Deprecated — no usar Slack en producción
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# Worker autónomo (daemon) — NO usa crons ni QStash.
# El worker se auto-gobierna: inbound → outbound → harvest, y duerme hasta el
# próximo desbloqueo de cuentas. Vercel es solo lectura (dashboard).
# ORCHESTRATOR_ENABLED=true                 # pon 'false' para pausar el daemon sin redeploy
# ORCHESTRATOR_MIN_SLEEP_MS=15000           # sueño mínimo entre ciclos
# ORCHESTRATOR_MAX_SLEEP_MS=21600000        # tope de sueño (re-chequeo periódico, 6 h)
# ORCHESTRATOR_ACTIVE_PAUSE_MS=30000        # pausa tras un ciclo con trabajo
# ORCHESTRATOR_NO_ACCOUNTS_SLEEP_MS=300000  # sueño si no hay cuentas usables
# ORCHESTRATOR_ERROR_BACKOFF_MS=60000       # backoff tras error de ciclo
# ORCHESTRATOR_INBOUND_POLL_MS=300000       # cadencia máx. de revisión de inbox (responder aunque haya cooldown, 5 min)
# HARVEST_PIPELINE_MIN=40                   # si hay menos leads fríos en cola, hace harvest

# Inbound (tuning del poll de respuestas)
# INBOUND_BATCH_SIZE=10
# INBOUND_THREAD_DELAY_MS=2000
# INBOUND_MAX_MESSAGES_PER_THREAD=30
# INBOUND_HEADED=true


# Versión del toolkit Gmail (requerida por Composio SDK)
# Verifica la vigente en https://docs.composio.dev/toolkits/gmail
COMPOSIO_GMAIL_TOOLKIT_VERSION=20260506_01

# Opcional: timeouts para polling del OTP
# COMPOSIO_2FA_TIMEOUT_MS=90000
# COMPOSIO_2FA_POLL_MS=5000
